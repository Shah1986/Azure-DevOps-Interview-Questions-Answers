Scenario

Suppose you have three Azure subscriptions:

Subscription	Resources
Subscription A	VM, Storage
Subscription B	SQL Database, Key Vault
Subscription C	App Service, Function App, Traffic Manager

Terraform can manage all of them in a single deployment.

Step 1. Configure Multiple Azure Providers
provider "azurerm" {
  alias           = "sub1"
  subscription_id = "xxxxxxxx-xxxx-xxxx"
  features {}
}

provider "azurerm" {
  alias           = "sub2"
  subscription_id = "yyyyyyyy-yyyy-yyyy"
  features {}
}

provider "azurerm" {
  alias           = "sub3"
  subscription_id = "zzzzzzzz-zzzz-zzzz"
  features {}
}
Step 2. Create Resource Groups
resource "azurerm_resource_group" "rg1" {
  provider = azurerm.sub1

  name     = "RG-INFRA"
  location = "Central India"
}

resource "azurerm_resource_group" "rg2" {
  provider = azurerm.sub2

  name     = "RG-DATABASE"
  location = "Central India"
}

resource "azurerm_resource_group" "rg3" {
  provider = azurerm.sub3

  name     = "RG-WEB"
  location = "Central India"
}
Step 3. Call Modules
Storage Account
module "storage" {

  source = "./modules/storage-account"

  providers = {
    azurerm = azurerm.sub1
  }

  rg_name = azurerm_resource_group.rg1.name
}
Virtual Machine
module "vm" {

  source = "./modules/virtual-machine"

  providers = {
    azurerm = azurerm.sub1
  }

  rg_name = azurerm_resource_group.rg1.name
}
Key Vault
module "keyvault" {

  source = "./modules/key-vault"

  providers = {
    azurerm = azurerm.sub2
  }

  rg_name = azurerm_resource_group.rg2.name
}
SQL Server
module "sqlserver" {

  source = "./modules/sql-server"

  providers = {
    azurerm = azurerm.sub2
  }

  rg_name = azurerm_resource_group.rg2.name
}
SQL Database
module "sqldb" {

  source = "./modules/sql-database"

  providers = {
    azurerm = azurerm.sub2
  }

  rg_name = azurerm_resource_group.rg2.name
}
App Service Plan
module "appserviceplan" {

  source = "./modules/app-service-plan"

  providers = {
    azurerm = azurerm.sub3
  }

  rg_name = azurerm_resource_group.rg3.name
}
App Service
module "appservice" {

  source = "./modules/app-service"

  providers = {
    azurerm = azurerm.sub3
  }

  rg_name = azurerm_resource_group.rg3.name
}
Function App
module "functionapp" {

  source = "./modules/function-app"

  providers = {
    azurerm = azurerm.sub3
  }

  rg_name = azurerm_resource_group.rg3.name
}
Traffic Manager
module "trafficmanager" {

  source = "./modules/traffic-manager"

  providers = {
    azurerm = azurerm.sub3
  }

  rg_name = azurerm_resource_group.rg3.name
}
